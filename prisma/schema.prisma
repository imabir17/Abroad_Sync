// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  leads     Lead[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  role      String   @default("Counselor") // Super Admin, Manager, Counselor
  password  String   // Simple auth for local dev
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations
  assignedLeads Lead[]        @relation("AssignedCounselor")
  createdLeads  Lead[]        @relation("CreatedLeads")
  interactions  Interaction[]
  tasks         Task[]
}

model Lead {
  id                    String   @id @default(cuid())
  fullName              String
  phone                 String?
  email                 String?
  lastStudyLevel        String?
  preferredStudyLevel   String?
  preferredCountry      String?
  preferredCourse       String?
  preferredIntake       String?
  
  // English Proficiency
  englishTestStatus     String? // e.g. Appeared, Planning, Not Required
  englishTestType       String? // e.g. IELTS, PTE, TOEFL, Duolingo, Other
  englishTestScore      String?
  
  // Detailed Academic Background
  sscGroup              String?
  sscYear               String?
  sscResult             String?
  
  hscGroup              String?
  hscYear               String?
  hscResult             String?
  
  bachelorsMajor        String?
  bachelorsYear         String?
  bachelorsCgpa         String?
  
  mastersMajor          String?
  mastersYear           String?
  mastersCgpa           String?

  workExperience        String?
  source                String?
  budget                String?
  
  initialNote           String?
  stage                 String   @default("New") // Pipeline stage
  rating                String?  // Very Good, Good, Moderate, Bad
  isFileOpened          Boolean  @default(false)
  fileOpenedAt          DateTime?
  contactedAt           DateTime?
  assignedAt            DateTime?
  assignedCounselorId   String?
  createdById           String?
  companyId             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  company               Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedCounselor     User?         @relation("AssignedCounselor", fields: [assignedCounselorId], references: [id])
  createdBy             User?         @relation("CreatedLeads", fields: [createdById], references: [id])
  interactions          Interaction[]
  tasks                 Task[]
  applications          Application[]
}

model Interaction {
  id          String   @id @default(cuid())
  leadId      String
  counselorId String
  type        String   // e.g., Note, StageChange
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  counselor   User     @relation(fields: [counselorId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  leadId      String?
  counselorId String
  description String
  dueDate     DateTime
  status      String   @default("Pending") // Pending, Completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  counselor   User     @relation(fields: [counselorId], references: [id], onDelete: Cascade)
}

model Application {
  id          String   @id @default(cuid())
  leadId      String
  country     String
  university  String
  courseName  String
  status      String   @default("Pending") // Pending, Offer Received, Rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
